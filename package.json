{
  "name": "openfederationpds",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/openfederation-sdk",
    "packages/openfederation-react",
    "packages/openfederation-lexicon"
  ],
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "main": "dist/src/index.js",
  "bin": {
    "ofc": "./dist/cli/ofc.js"
  },
  "scripts": {
    "build": "tsc && npm run build:sdk",
    "build:sdk": "cd packages/openfederation-sdk && NPM_CONFIG_PRODUCTION=false npm install && npm run build && mkdir -p ../../dist/sdk && cp dist/index.global.js ../../dist/sdk/v1.js",
    "start": "node dist/src/index.js",
    "dev": "node --loader ts-node/esm src/index.ts",
    "cli": "node dist/cli/ofc.js",
    "cli:dev": "node --loader ts-node/esm cli/ofc.ts",
    "db:init": "node --loader ts-node/esm scripts/init-db.ts",
    "db:check": "node --loader ts-node/esm scripts/check-db.ts",
    "db:seed-admin": "node --loader ts-node/esm scripts/seed-bootstrap-admin.ts",
    "lexicon:validate": "node --loader ts-node/esm scripts/validate-lexicon-revisions.ts",
    "lexicon:generate": "node --loader ts-node/esm scripts/generate-lexicon-contracts.ts",
    "lexicon:check": "npm run lexicon:validate && node --loader ts-node/esm scripts/generate-lexicon-contracts.ts --check",
    "validate:lexicon": "node --loader ts-node/esm scripts/build-lexicon-package.ts --validate-only",
    "build:lexicon": "npm run lexicon:generate && node --loader ts-node/esm scripts/build-lexicon-package.ts && cd packages/openfederation-lexicon && NPM_CONFIG_PRODUCTION=false npm install && npm run build",
    "build:lexicon-docs": "node --loader ts-node/esm scripts/build-lexicon-docs.ts",
    "plc:dev": "PORT=2582 node node_modules/@did-plc/server/dist/bin.js",
    "test": "node --loader ts-node/esm --test tests/security-*.test.ts",
    "test:unit": "node --loader ts-node/esm --test tests/security-validation.test.ts tests/security-jwt.test.ts tests/security-encryption.test.ts tests/security-guards.test.ts tests/security-middleware.test.ts",
    "test:api": "TEST_DB_NAME=${TEST_DB_NAME:-openfederation_pds_test} vitest run",
    "test:api:watch": "TEST_DB_NAME=${TEST_DB_NAME:-openfederation_pds_test} vitest",
    "test:e2e": "TEST_DB_NAME=${TEST_DB_NAME:-openfederation_pds_test} vitest run tests/e2e/"
  },
  "keywords": [
    "atproto",
    "decentralized",
    "did",
    "federation",
    "identity",
    "pds",
    "personal-data-server"
  ],
  "author": "OpenFederation Contributors",
  "license": "MIT OR Apache-2.0",
  "description": "Personal Data Server (PDS) for OpenFederation communities, built on the AT Protocol",
  "repository": {
    "type": "git",
    "url": "https://github.com/athlon-misa/openfederation-pds.git"
  },
  "homepage": "https://github.com/athlon-misa/openfederation-pds",
  "bugs": {
    "url": "https://github.com/athlon-misa/openfederation-pds/issues"
  },
  "dependencies": {
    "@atproto/api": "^0.18.20",
    "@atproto/crypto": "^0.4.5",
    "@atproto/identity": "^0.4.10",
    "@atproto/lexicon": "^0.6.1",
    "@atproto/oauth-client-node": "^0.3.17",
    "@atproto/oauth-provider": "^0.15.11",
    "@atproto/repo": "^0.8.12",
    "@atproto/xrpc": "^0.7.7",
    "@aws-sdk/client-s3": "^3.1018.0",
    "bcryptjs": "^3.0.3",
    "bs58": "^6.0.0",
    "chalk": "^5.6.2",
    "commander": "^13.1.0",
    "dotenv": "^17.2.4",
    "ethers": "^6.16.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "jose": "^5.10.0",
    "multiformats": "^13.4.2",
    "nodemailer": "^8.0.4",
    "pg": "^8.18.0",
    "secrets.js-grempe": "^2.0.0",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@did-plc/server": "^0.0.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.6",
    "@types/node": "^25.2.1",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^7.2.0",
    "happy-dom": "^20.9.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
