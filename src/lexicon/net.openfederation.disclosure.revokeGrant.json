{
  "lexicon": 1,
  "id": "net.openfederation.disclosure.revokeGrant",
  "revision": 1,
  "description": "Revoke a viewing grant. Only the attestation subject (grant creator) can revoke.",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Mark a viewing grant as revoked so it can no longer be redeemed.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "ref",
          "ref": "#input"
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "ref",
          "ref": "#output"
        }
      },
      "errors": [
        {
          "name": "InvalidRequest",
          "description": "Missing required fields."
        },
        {
          "name": "NotFound",
          "description": "Viewing grant not found."
        },
        {
          "name": "Forbidden",
          "description": "Only the attestation subject can revoke."
        },
        {
          "name": "AlreadyRevoked",
          "description": "The grant is already revoked."
        }
      ]
    },
    "input": {
      "type": "object",
      "properties": {
        "grantId": {
          "type": "string",
          "description": "The viewing grant ID to revoke."
        }
      },
      "required": [
        "grantId"
      ]
    },
    "output": {
      "type": "object",
      "properties": {
        "success": {
          "type": "boolean",
          "description": "True if the grant was successfully revoked."
        }
      },
      "required": [
        "success"
      ]
    }
  }
}
