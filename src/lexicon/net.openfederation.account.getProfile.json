{
  "lexicon": 1,
  "id": "net.openfederation.account.getProfile",
  "description": "Get a user's profile, including standard ATProto fields and any custom profile collections.",
  "defs": {
    "main": {
      "type": "query",
      "description": "Returns the user's app.bsky.actor.profile and any custom profile collections found in their repo.",
      "parameters": {
        "type": "params",
        "properties": {
          "did": { "type": "string", "description": "The user's DID." }
        },
        "required": ["did"]
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "ref",
          "ref": "#output"
        }
      },
      "errors": [
        { "name": "InvalidRequest", "description": "Missing or invalid DID." },
        { "name": "ProfileNotFound", "description": "No profile found for this DID." }
      ]
    },
    "output": {
      "type": "object",
      "properties": {
        "did": { "type": "string" },
        "handle": { "type": "string" },
        "profile": { "type": "unknown", "description": "app.bsky.actor.profile record." },
        "customProfiles": { "type": "unknown", "description": "Map of custom collection NSID to record value." }
      },
      "required": ["did", "profile"]
    }
  }
}
