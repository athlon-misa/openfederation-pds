{
  "lexicon": 1,
  "id": "net.openfederation.vault.getCustodialSecret",
  "revision": 3,
  "defs": {
    "main": {
      "type": "query",
      "description": "Retrieve the encrypted custodial secret for a given chain. Returns 404 if not found.",
      "parameters": {
        "type": "params",
        "required": [
          "chain"
        ],
        "properties": {
          "chain": {
            "type": "string",
            "maxLength": 64
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": [
            "secretType",
            "chain",
            "encryptedBlob",
            "walletAddress",
            "createdAt",
            "updatedAt"
          ],
          "properties": {
            "secretType": {
              "type": "string"
            },
            "chain": {
              "type": "string"
            },
            "encryptedBlob": {
              "type": "string"
            },
            "walletAddress": {
              "type": "string"
            },
            "createdAt": {
              "type": "string"
            },
            "updatedAt": {
              "type": "string"
            }
          }
        }
      },
      "errors": [
        {
          "name": "NotFound",
          "description": "Referenced resource was not found."
        }
      ]
    }
  }
}
