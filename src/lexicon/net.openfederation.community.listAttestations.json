{
  "lexicon": 1,
  "id": "net.openfederation.community.listAttestations",
  "revision": 2,
  "description": "List attestations issued by a community. Public endpoint for verification.",
  "defs": {
    "main": {
      "type": "query",
      "description": "List attestation records, optionally filtered by subject or type.",
      "parameters": {
        "type": "params",
        "properties": {
          "communityDid": {
            "type": "string",
            "description": "The community DID."
          },
          "subjectDid": {
            "type": "string",
            "description": "Optional: filter by subject DID."
          },
          "type": {
            "type": "string",
            "description": "Optional: filter by attestation type."
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100,
            "default": 50
          },
          "cursor": {
            "type": "string",
            "description": "Pagination cursor."
          }
        },
        "required": [
          "communityDid"
        ]
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "ref",
          "ref": "#output"
        }
      },
      "errors": [
        {
          "name": "InvalidRequest",
          "description": "Missing communityDid."
        }
      ]
    },
    "attestationItem": {
      "type": "object",
      "properties": {
        "uri": {
          "type": "string"
        },
        "rkey": {
          "type": "string"
        },
        "subjectDid": {
          "type": "string"
        },
        "subjectHandle": {
          "type": "string"
        },
        "subjectDisplayName": {
          "type": "string",
          "description": "Resolved display name of the subject."
        },
        "subjectAvatarUrl": {
          "type": "string",
          "description": "Resolved avatar URL of the subject, or null when not set."
        },
        "type": {
          "type": "string"
        },
        "claim": {
          "type": "unknown"
        },
        "issuedAt": {
          "type": "string"
        },
        "expiresAt": {
          "type": "string"
        }
      },
      "required": [
        "uri",
        "rkey",
        "subjectDid",
        "subjectHandle",
        "subjectDisplayName",
        "type",
        "claim",
        "issuedAt"
      ]
    },
    "output": {
      "type": "object",
      "properties": {
        "attestations": {
          "type": "array",
          "items": {
            "type": "ref",
            "ref": "#attestationItem"
          }
        },
        "cursor": {
          "type": "string"
        }
      },
      "required": [
        "attestations"
      ]
    }
  }
}
