{
  "lexicon": 1,
  "id": "net.openfederation.community.listMine",
  "description": "List communities the authenticated user belongs to. Requires auth.",
  "defs": {
    "main": {
      "type": "query",
      "description": "Retrieve a paginated list of communities the user is a member of.",
      "parameters": {
        "type": "params",
        "properties": {
          "limit": { "type": "integer", "minimum": 1, "maximum": 100, "default": 50, "description": "Maximum number of results to return." },
          "offset": { "type": "integer", "default": 0, "description": "Number of results to skip for pagination." }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "ref",
          "ref": "#output"
        }
      }
    },
    "communityItem": {
      "type": "object",
      "properties": {
        "did": { "type": "string", "description": "The community DID." },
        "handle": { "type": "string", "description": "The community handle." },
        "didMethod": { "type": "string", "description": "The DID method used." },
        "displayName": { "type": "string", "description": "Display name of the community." },
        "description": { "type": "string", "description": "Description of the community." },
        "createdAt": { "type": "string", "format": "datetime", "description": "When the community was created." },
        "role": { "type": "string", "description": "The user's role in this community (owner, admin, moderator, member)." }
      },
      "required": ["did", "handle", "didMethod", "createdAt", "role"]
    },
    "output": {
      "type": "object",
      "properties": {
        "communities": { "type": "array", "items": { "type": "ref", "ref": "#communityItem" } },
        "limit": { "type": "integer" },
        "offset": { "type": "integer" }
      },
      "required": ["communities", "limit", "offset"]
    }
  }
}
