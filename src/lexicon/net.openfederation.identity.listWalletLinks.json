{
  "lexicon": 1,
  "id": "net.openfederation.identity.listWalletLinks",
  "revision": 1,
  "description": "List all wallet links for the authenticated user.",
  "defs": {
    "main": {
      "type": "query",
      "description": "Returns all blockchain wallets linked to the authenticated user's DID.",
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "ref",
          "ref": "#output"
        }
      },
      "errors": [
        { "name": "AuthRequired", "description": "Authentication is required." }
      ]
    },
    "output": {
      "type": "object",
      "properties": {
        "walletLinks": {
          "type": "array",
          "items": {
            "type": "ref",
            "ref": "#walletLink"
          }
        }
      },
      "required": ["walletLinks"]
    },
    "walletLink": {
      "type": "object",
      "properties": {
        "chain": { "type": "string", "description": "Blockchain identifier (ethereum, solana)." },
        "walletAddress": { "type": "string", "description": "The wallet address." },
        "label": { "type": "string", "description": "User-assigned label for this link." },
        "linkedAt": { "type": "string", "description": "ISO 8601 timestamp of when the link was created." }
      },
      "required": ["chain", "walletAddress", "linkedAt"]
    }
  }
}
