{
  "lexicon": 1,
  "id": "net.openfederation.oracle.revokeCredential",
  "revision": 1,
  "description": "Revoke an Oracle credential. Admin only.",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Revoke an Oracle credential by ID.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": [
            "credentialId"
          ],
          "properties": {
            "credentialId": {
              "type": "string",
              "description": "ID of the credential to revoke."
            }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": [
            "success"
          ],
          "properties": {
            "success": {
              "type": "boolean"
            }
          }
        }
      },
      "errors": [
        {
          "name": "NotFound",
          "description": "Credential not found."
        }
      ]
    }
  }
}
