{
  "lexicon": 1,
  "id": "net.openfederation.community.listApplications",
  "description": "List linked applications for a community.",
  "defs": {
    "main": {
      "type": "query",
      "description": "List all applications linked to a community. Public endpoint for discovery.",
      "parameters": {
        "type": "params",
        "properties": {
          "did": { "type": "string", "description": "DID of the community." }
        },
        "required": ["did"]
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "properties": {
            "applications": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "uri": { "type": "string", "description": "AT URI of the application record." },
                  "rkey": { "type": "string", "description": "Record key (TID)." },
                  "cid": { "type": "string", "description": "Content CID of the record." },
                  "appType": { "type": "string", "description": "Type of application." },
                  "instanceUrl": { "type": "string", "description": "URL of the application instance." },
                  "displayName": { "type": "string", "description": "Display name of the application." },
                  "linkedAt": { "type": "string", "description": "ISO 8601 timestamp of when the app was linked." },
                  "linkedBy": { "type": "string", "description": "DID of the user who linked the app." }
                },
                "required": ["uri", "rkey", "cid", "appType", "instanceUrl", "linkedAt", "linkedBy"]
              }
            }
          },
          "required": ["applications"]
        }
      },
      "errors": [
        { "name": "InvalidRequest", "description": "Missing required query parameter." },
        { "name": "NotFound", "description": "Community not found." }
      ]
    }
  }
}
