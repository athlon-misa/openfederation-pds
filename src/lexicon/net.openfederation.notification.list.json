{
  "lexicon": 1,
  "id": "net.openfederation.notification.list",
  "revision": 1,
  "description": "List the caller's notifications, newest first, with optional category filter and unread-only flag.",
  "defs": {
    "main": {
      "type": "query",
      "description": "Retrieve paginated notifications for the caller.",
      "parameters": {
        "type": "params",
        "properties": {
          "category": {
            "type": "string",
            "description": "Optional: filter to a specific category (e.g. 'contact-request')."
          },
          "unreadOnly": {
            "type": "boolean",
            "default": false
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100,
            "default": 50
          },
          "cursor": {
            "type": "string"
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "ref",
          "ref": "#output"
        }
      }
    },
    "notificationItem": {
      "type": "object",
      "required": ["id", "category", "payload", "createdAt"],
      "properties": {
        "id": { "type": "string" },
        "category": { "type": "string" },
        "payload": { "type": "unknown" },
        "createdAt": { "type": "string", "format": "datetime" },
        "readAt": { "type": "string", "format": "datetime" }
      }
    },
    "output": {
      "type": "object",
      "required": ["notifications"],
      "properties": {
        "notifications": {
          "type": "array",
          "items": { "type": "ref", "ref": "#notificationItem" }
        },
        "cursor": { "type": "string" }
      }
    }
  }
}
