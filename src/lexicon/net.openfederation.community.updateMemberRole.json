{
  "lexicon": 1,
  "id": "net.openfederation.community.updateMemberRole",
  "description": "Change a community member's role. Only community owner or PDS admin can change roles.",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Promote or demote a community member by rewriting their member record.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "properties": {
            "communityDid": { "type": "string", "description": "The community DID." },
            "memberDid": { "type": "string", "description": "The DID of the member to update." },
            "role": { "type": "string", "enum": ["moderator", "member"], "description": "New role. Cannot set to 'owner'." }
          },
          "required": ["communityDid", "memberDid", "role"]
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "properties": {
            "uri": { "type": "string" },
            "cid": { "type": "string" },
            "role": { "type": "string" }
          },
          "required": ["uri", "cid", "role"]
        }
      },
      "errors": [
        { "name": "InvalidRequest", "description": "Missing fields or invalid role." },
        { "name": "NotMember", "description": "Target DID is not a member of this community." },
        { "name": "CannotChangeOwner", "description": "Cannot change the owner's role." }
      ]
    }
  }
}
