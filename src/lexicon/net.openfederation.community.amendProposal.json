{
  "lexicon": 1,
  "id": "net.openfederation.community.amendProposal",
  "description": "Amend an open governance proposal. Resets votes and extends expiration.",
  "defs": {
    "main": {
      "type": "procedure",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "ref",
          "ref": "#input"
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "ref",
          "ref": "#output"
        }
      },
      "errors": [
        { "name": "InvalidRequest", "description": "Missing fields." },
        { "name": "ProposalNotFound", "description": "No proposal with given rkey." },
        { "name": "ProposalClosed", "description": "Proposal is not open." }
      ]
    },
    "input": {
      "type": "object",
      "properties": {
        "communityDid": { "type": "string" },
        "proposalRkey": { "type": "string" },
        "proposedRecord": { "type": "unknown", "description": "New proposed record." },
        "reason": { "type": "string", "description": "Optional reason for amendment." }
      },
      "required": ["communityDid", "proposalRkey", "proposedRecord"]
    },
    "output": {
      "type": "object",
      "properties": {
        "uri": { "type": "string" },
        "cid": { "type": "string" },
        "amendmentCount": { "type": "integer" }
      },
      "required": ["uri", "cid", "amendmentCount"]
    }
  }
}
