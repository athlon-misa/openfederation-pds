{
  "lexicon": 1,
  "id": "net.openfederation.attestation.verifyCommitment",
  "revision": 1,
  "description": "Verify a private attestation's commitment hash without revealing content.",
  "defs": {
    "main": {
      "type": "query",
      "description": "Returns the commitment hash and metadata for a private attestation. Never returns decrypted content.",
      "parameters": {
        "type": "params",
        "properties": {
          "communityDid": {
            "type": "string",
            "description": "The community DID that issued the attestation."
          },
          "rkey": {
            "type": "string",
            "description": "The attestation record key."
          }
        },
        "required": [
          "communityDid",
          "rkey"
        ]
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "ref",
          "ref": "#output"
        }
      },
      "errors": [
        {
          "name": "InvalidRequest",
          "description": "Missing required parameters."
        },
        {
          "name": "NotFound",
          "description": "No encryption metadata found."
        }
      ]
    },
    "output": {
      "type": "object",
      "properties": {
        "commitment": {
          "type": "unknown",
          "description": "Object containing hash and optional schemaHash."
        },
        "issuerDid": {
          "type": "string",
          "description": "The community DID that issued the attestation."
        },
        "visibility": {
          "type": "string",
          "description": "Visibility mode of the attestation."
        },
        "issuedAt": {
          "type": "string",
          "description": "ISO 8601 timestamp of when the attestation was issued."
        },
        "revoked": {
          "type": "boolean",
          "description": "Whether the attestation has been revoked (deleted)."
        }
      },
      "required": [
        "commitment",
        "issuerDid",
        "visibility",
        "issuedAt",
        "revoked"
      ]
    }
  }
}
