{
  "lexicon": 1,
  "id": "net.openfederation.community.issueAttestation",
  "description": "Issue a signed attestation for a community member. Stored in the community's ATProto repo.",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Create an attestation record certifying a member's role, status, or credentials.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "properties": {
            "communityDid": { "type": "string", "description": "The community DID issuing the attestation." },
            "subjectDid": { "type": "string", "description": "The DID of the person being attested." },
            "subjectHandle": { "type": "string", "description": "Handle of the subject (for display)." },
            "type": { "type": "string", "enum": ["membership", "role", "credential"], "description": "Attestation type." },
            "claim": { "type": "object", "description": "Arbitrary claim data (role, position, status, etc.)." },
            "expiresAt": { "type": "string", "description": "Optional ISO 8601 expiration timestamp." }
          },
          "required": ["communityDid", "subjectDid", "subjectHandle", "type", "claim"]
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "properties": {
            "uri": { "type": "string" },
            "cid": { "type": "string" },
            "rkey": { "type": "string" }
          },
          "required": ["uri", "cid", "rkey"]
        }
      },
      "errors": [
        { "name": "InvalidRequest", "description": "Missing required fields." },
        { "name": "NotMember", "description": "Subject is not a member of this community." }
      ]
    }
  }
}
