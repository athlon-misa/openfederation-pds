{
  "lexicon": 1,
  "id": "net.openfederation.wallet.listConsents",
  "revision": 2,
  "description": "List the authenticated user's active (unrevoked, unexpired) Tier 1 signing consent grants.",
  "defs": {
    "main": {
      "type": "query",
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["consents"],
          "properties": {
            "consents": {
              "type": "array",
              "items": {
                "type": "ref",
                "ref": "#consentEntry"
              }
            }
          }
        }
      }
    },
    "consentEntry": {
      "type": "object",
      "description": "Single active Tier 1 signing consent grant.",
      "required": ["id", "dappOrigin", "grantedAt", "expiresAt"],
      "properties": {
        "id": { "type": "string" },
        "dappOrigin": { "type": "string" },
        "chain": { "type": "string" },
        "walletAddress": { "type": "string" },
        "grantedAt": { "type": "string" },
        "expiresAt": { "type": "string" }
      }
    }
  }
}
