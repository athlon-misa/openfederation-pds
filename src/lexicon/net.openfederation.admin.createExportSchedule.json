{
  "lexicon": 1,
  "id": "net.openfederation.admin.createExportSchedule",
  "revision": 1,
  "description": "Create or update an export schedule for a community.",
  "defs": {
    "main": {
      "type": "procedure",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "properties": {
            "communityDid": {
              "type": "string"
            },
            "interval": {
              "type": "string",
              "enum": [
                "daily",
                "weekly",
                "monthly"
              ]
            },
            "retentionCount": {
              "type": "integer"
            }
          },
          "required": [
            "communityDid",
            "interval"
          ]
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string"
            },
            "communityDid": {
              "type": "string"
            },
            "interval": {
              "type": "string"
            },
            "retentionCount": {
              "type": "integer"
            }
          },
          "required": [
            "id",
            "communityDid",
            "interval"
          ]
        }
      }
    }
  }
}
