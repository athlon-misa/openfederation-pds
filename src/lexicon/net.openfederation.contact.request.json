{
  "lexicon": 1,
  "id": "net.openfederation.contact.request",
  "revision": 1,
  "description": "A pending contact request. Lives on the requester's repo.",
  "defs": {
    "main": {
      "type": "record",
      "description": "Pending contact request record.",
      "key": "tid",
      "record": {
        "type": "object",
        "required": ["subject", "createdAt"],
        "properties": {
          "subject": {
            "type": "string",
            "format": "did",
            "description": "DID of the recipient."
          },
          "note": {
            "type": "string",
            "maxLength": 280,
            "description": "Optional message attached to the request."
          },
          "createdAt": {
            "type": "string",
            "format": "datetime"
          }
        }
      }
    }
  }
}
