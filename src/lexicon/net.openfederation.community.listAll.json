{
  "lexicon": 1,
  "id": "net.openfederation.community.listAll",
  "revision": 1,
  "description": "List communities. Requires auth. Public mode excludes user's own communities; admin mode 'all' shows everything.",
  "defs": {
    "main": {
      "type": "query",
      "description": "Retrieve a paginated list of communities.",
      "parameters": {
        "type": "params",
        "properties": {
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100,
            "default": 50,
            "description": "Maximum number of results to return."
          },
          "offset": {
            "type": "integer",
            "default": 0,
            "description": "Number of results to skip for pagination."
          },
          "mode": {
            "type": "string",
            "description": "Listing mode: public or all. 'public' excludes user's communities; 'all' shows everything (admin only)."
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "ref",
          "ref": "#output"
        }
      }
    },
    "communityItem": {
      "type": "object",
      "properties": {
        "did": {
          "type": "string",
          "description": "The community DID."
        },
        "handle": {
          "type": "string",
          "description": "The community handle."
        },
        "didMethod": {
          "type": "string",
          "description": "The DID method used."
        },
        "displayName": {
          "type": "string",
          "description": "Display name of the community."
        },
        "description": {
          "type": "string",
          "description": "Description of the community."
        },
        "visibility": {
          "type": "string",
          "description": "Community visibility (public or private)."
        },
        "joinPolicy": {
          "type": "string",
          "description": "Join policy (open or approval)."
        },
        "memberCount": {
          "type": "integer",
          "description": "Number of members in the community."
        },
        "createdAt": {
          "type": "string",
          "format": "datetime",
          "description": "When the community was created."
        },
        "status": {
          "type": "string",
          "description": "Community status."
        },
        "isMember": {
          "type": "boolean",
          "description": "Whether the authenticated user is a member."
        },
        "joinRequestStatus": {
          "type": "string",
          "description": "Status of the user's join request, or null."
        }
      },
      "required": [
        "did",
        "handle",
        "didMethod",
        "visibility",
        "joinPolicy",
        "memberCount",
        "createdAt",
        "status",
        "isMember"
      ]
    },
    "output": {
      "type": "object",
      "properties": {
        "communities": {
          "type": "array",
          "items": {
            "type": "ref",
            "ref": "#communityItem"
          }
        },
        "total": {
          "type": "integer",
          "description": "Total number of matching communities."
        },
        "limit": {
          "type": "integer"
        },
        "offset": {
          "type": "integer"
        }
      },
      "required": [
        "communities",
        "total",
        "limit",
        "offset"
      ]
    }
  }
}
