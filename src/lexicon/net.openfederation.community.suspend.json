{
  "lexicon": 1,
  "id": "net.openfederation.community.suspend",
  "description": "Suspend a community. Requires admin role. Reversible suspension per AT Protocol composable moderation.",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Suspend a community, temporarily restricting its activity. This is reversible via unsuspend.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "properties": {
            "did": { "type": "string", "description": "The DID of the community to suspend." },
            "reason": { "type": "string", "description": "Optional reason for the suspension." }
          },
          "required": ["did"]
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "properties": {
            "did": { "type": "string", "description": "The community DID." },
            "status": { "type": "string", "description": "The new status, always 'suspended'." },
            "reason": { "type": "string", "description": "The reason for suspension, or null if not provided." }
          },
          "required": ["did", "status"]
        }
      },
      "errors": [
        { "name": "InvalidRequest", "description": "Missing or invalid DID." },
        { "name": "NotFound", "description": "Community not found." },
        { "name": "AlreadySuspended", "description": "The community is already suspended." },
        { "name": "AlreadyTakenDown", "description": "The community has been taken down and cannot be suspended." }
      ]
    }
  }
}
