{
  "lexicon": 1,
  "id": "net.openfederation.community.linkApplication",
  "revision": 1,
  "description": "Link an external application to a community. Creates a repo record for the linked app.",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Link a fediverse application (Mastodon, Matrix, Discourse, etc.) to a community. Only community owner or PDS admin.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "properties": {
            "communityDid": {
              "type": "string",
              "description": "DID of the community to link the application to."
            },
            "appType": {
              "type": "string",
              "enum": [
                "mastodon",
                "matrix",
                "discourse",
                "custom"
              ],
              "description": "Type of application being linked."
            },
            "instanceUrl": {
              "type": "string",
              "description": "HTTPS URL of the application instance."
            },
            "displayName": {
              "type": "string",
              "description": "Optional display name for the linked application."
            }
          },
          "required": [
            "communityDid",
            "appType",
            "instanceUrl"
          ]
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "properties": {
            "uri": {
              "type": "string",
              "description": "AT URI of the created application record."
            },
            "rkey": {
              "type": "string",
              "description": "Record key (TID) of the created record."
            },
            "appType": {
              "type": "string",
              "description": "Type of application linked."
            },
            "instanceUrl": {
              "type": "string",
              "description": "URL of the application instance."
            },
            "displayName": {
              "type": "string",
              "description": "Display name of the linked application."
            }
          },
          "required": [
            "uri",
            "rkey",
            "appType",
            "instanceUrl"
          ]
        }
      },
      "errors": [
        {
          "name": "InvalidRequest",
          "description": "Missing required fields or invalid appType/URL."
        },
        {
          "name": "Conflict",
          "description": "This instance URL is already linked to the community."
        },
        {
          "name": "NotFound",
          "description": "Community not found."
        },
        {
          "name": "Forbidden",
          "description": "Insufficient privileges (owner or admin required)."
        }
      ]
    }
  }
}
