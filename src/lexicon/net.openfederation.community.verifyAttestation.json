{
  "lexicon": 1,
  "id": "net.openfederation.community.verifyAttestation",
  "revision": 1,
  "description": "Verify an attestation exists in a community repo. Record existence = validity.",
  "defs": {
    "main": {
      "type": "query",
      "description": "Check if an attestation record exists and return it with verification metadata.",
      "parameters": {
        "type": "params",
        "properties": {
          "communityDid": {
            "type": "string",
            "description": "The community DID."
          },
          "rkey": {
            "type": "string",
            "description": "The attestation record key."
          }
        },
        "required": [
          "communityDid",
          "rkey"
        ]
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "ref",
          "ref": "#output"
        }
      },
      "errors": [
        {
          "name": "InvalidRequest",
          "description": "Missing required parameters."
        }
      ]
    },
    "output": {
      "type": "object",
      "properties": {
        "valid": {
          "type": "boolean"
        },
        "attestation": {
          "type": "unknown"
        },
        "communityDid": {
          "type": "string"
        },
        "communityHandle": {
          "type": "string"
        },
        "expired": {
          "type": "boolean"
        }
      },
      "required": [
        "valid",
        "communityDid"
      ]
    }
  }
}
