{
  "lexicon": 1,
  "id": "net.openfederation.vault.storeCustodialSecret",
  "revision": 2,
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Store an encrypted custodial secret (e.g. wallet mnemonic) for the authenticated user. The blob is stored opaquely; the PDS never decrypts it.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["secretType", "chain", "encryptedBlob", "walletAddress"],
          "properties": {
            "secretType": { "type": "string", "maxLength": 64 },
            "chain": { "type": "string", "maxLength": 64 },
            "encryptedBlob": { "type": "string", "maxLength": 65536 },
            "walletAddress": { "type": "string", "maxLength": 256 }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["success", "secretId"],
          "properties": {
            "success": { "type": "boolean" },
            "secretId": { "type": "string" }
          }
        }
      }
    }
  }
}
