{
  "lexicon": 1,
  "id": "net.openfederation.account.reject",
  "description": "Reject a pending user account. Requires admin or moderator role.",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Reject a pending user registration. At least one of userId, handle, or email must be provided.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "properties": {
            "userId": { "type": "string", "description": "The user's internal ID." },
            "handle": { "type": "string", "description": "The user's handle." },
            "email": { "type": "string", "description": "The user's email address." }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "properties": {
            "id": { "type": "string" },
            "handle": { "type": "string" },
            "email": { "type": "string" },
            "status": { "type": "string", "description": "Always 'rejected' on success." }
          },
          "required": ["id", "handle", "email", "status"]
        }
      },
      "errors": [
        { "name": "InvalidRequest", "description": "At least one of userId, handle, or email must be provided." },
        { "name": "NotFound", "description": "No pending user found matching the provided identifier." }
      ]
    }
  }
}
