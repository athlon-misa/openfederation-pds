{
  "lexicon": 1,
  "id": "net.openfederation.contact.listIncomingRequests",
  "revision": 1,
  "description": "List pending contact requests addressed to the caller.",
  "defs": {
    "main": {
      "type": "query",
      "description": "Retrieve pending incoming contact requests.",
      "parameters": {
        "type": "params",
        "properties": {
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100,
            "default": 50
          },
          "cursor": {
            "type": "string",
            "description": "Pagination cursor."
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "ref",
          "ref": "#output"
        }
      }
    },
    "requestItem": {
      "type": "object",
      "required": ["rkey", "fromDid", "fromHandle", "createdAt"],
      "properties": {
        "rkey": {
          "type": "string",
          "description": "rkey of the request record on the requester's repo."
        },
        "fromDid": {
          "type": "string"
        },
        "fromHandle": {
          "type": "string"
        },
        "fromDisplayName": {
          "type": "string"
        },
        "fromAvatarUrl": {
          "type": "string"
        },
        "note": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "datetime"
        }
      }
    },
    "output": {
      "type": "object",
      "required": ["requests"],
      "properties": {
        "requests": {
          "type": "array",
          "items": {
            "type": "ref",
            "ref": "#requestItem"
          }
        },
        "cursor": {
          "type": "string"
        }
      }
    }
  }
}
