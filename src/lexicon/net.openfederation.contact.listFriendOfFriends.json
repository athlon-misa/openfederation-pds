{
  "lexicon": 1,
  "id": "net.openfederation.contact.listFriendOfFriends",
  "revision": 1,
  "description": "Discover contacts of the caller's contacts who are not already the caller's contacts. Each result includes a mutual-count. Only includes DIDs whose owners have opted into friend-of-friend discovery.",
  "defs": {
    "main": {
      "type": "query",
      "description": "List second-degree contacts sorted by mutual-count descending.",
      "parameters": {
        "type": "params",
        "properties": {
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100,
            "default": 50
          },
          "cursor": {
            "type": "string"
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "ref",
          "ref": "#output"
        }
      }
    },
    "fofItem": {
      "type": "object",
      "required": ["did", "handle", "mutualCount"],
      "properties": {
        "did": { "type": "string" },
        "handle": { "type": "string" },
        "displayName": { "type": "string" },
        "mutualCount": {
          "type": "integer",
          "description": "Number of the caller's contacts who know this person."
        }
      }
    },
    "output": {
      "type": "object",
      "required": ["suggestions"],
      "properties": {
        "suggestions": {
          "type": "array",
          "items": { "type": "ref", "ref": "#fofItem" }
        },
        "cursor": { "type": "string" }
      }
    }
  }
}
