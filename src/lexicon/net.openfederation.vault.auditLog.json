{
  "lexicon": 1,
  "id": "net.openfederation.vault.auditLog",
  "revision": 1,
  "description": "Retrieve vault audit log entries for the authenticated user.",
  "defs": {
    "main": {
      "type": "query",
      "description": "Returns vault audit log entries for the authenticated user's key custody operations.",
      "parameters": {
        "type": "params",
        "properties": {
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100,
            "default": 50,
            "description": "Maximum number of entries to return."
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": [
            "entries"
          ],
          "properties": {
            "entries": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "id",
                  "userDid",
                  "action",
                  "createdAt"
                ],
                "properties": {
                  "id": {
                    "type": "string"
                  },
                  "userDid": {
                    "type": "string"
                  },
                  "action": {
                    "type": "string"
                  },
                  "actorDid": {
                    "type": "string"
                  },
                  "shareIndex": {
                    "type": "integer"
                  },
                  "metadata": {
                    "type": "object"
                  },
                  "createdAt": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
