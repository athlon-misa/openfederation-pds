{
  "lexicon": 1,
  "id": "net.openfederation.account.listSessions",
  "revision": 1,
  "description": "List active sessions for the authenticated user. Admins can list sessions for any user by DID.",
  "defs": {
    "main": {
      "type": "query",
      "description": "Get a list of active sessions.",
      "parameters": {
        "type": "params",
        "properties": {
          "did": {
            "type": "string",
            "description": "DID of user to list sessions for (admin only). Omit for own sessions."
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": [
            "sessions"
          ],
          "properties": {
            "sessions": {
              "type": "array",
              "items": {
                "type": "ref",
                "ref": "#sessionInfo"
              }
            }
          }
        }
      }
    },
    "sessionInfo": {
      "type": "object",
      "required": [
        "id",
        "createdAt",
        "expiresAt"
      ],
      "properties": {
        "id": {
          "type": "string",
          "description": "Session ID (first 8 chars only for security)."
        },
        "createdAt": {
          "type": "string",
          "format": "datetime"
        },
        "lastUsedAt": {
          "type": "string",
          "format": "datetime"
        },
        "expiresAt": {
          "type": "string",
          "format": "datetime"
        },
        "isCurrent": {
          "type": "boolean",
          "description": "Whether this is the session making the request."
        }
      }
    }
  }
}
