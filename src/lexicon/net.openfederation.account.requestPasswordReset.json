{
  "lexicon": 1,
  "id": "net.openfederation.account.requestPasswordReset",
  "revision": 1,
  "description": "Request a password reset email.",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Sends a password reset link to the email associated with the account. Always returns success to avoid leaking account existence.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": [
            "identifier"
          ],
          "properties": {
            "identifier": {
              "type": "string",
              "description": "Email address or handle."
            }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": [
            "success"
          ],
          "properties": {
            "success": {
              "type": "boolean"
            }
          }
        }
      }
    }
  }
}
