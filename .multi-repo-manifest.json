{
  "version": "1.0",
  "project": "OpenFederation Gaming Platform",
  "repos": [
    {
      "name": "OpenFederationPDS",
      "url": "https://github.com/athlon-misa/openfederation-pds",
      "owns": [
        "@openfederation/sdk",
        "openfederation-pds-api",
        "openfederation-plc-directory",
        "openfederation-web-ui"
      ],
      "depends_on": []
    },
    {
      "name": "grvty-leaderboards",
      "url": "https://github.com/athlon-misa/grvty-leaderboards",
      "owns": [
        "@grvty/leaderboard-api",
        "@grvty/auth-bff",
        "@grvty/leaderboard-worker",
        "@grvty/contracts",
        "@grvty/identity"
      ],
      "depends_on": [
        {
          "package": "@openfederation/sdk",
          "source_repo": "OpenFederationPDS",
          "version": "0.1.0"
        }
      ]
    },
    {
      "name": "FlappySoccer",
      "url": "https://github.com/athlon-misa/flappysoccer",
      "owns": [
        "flappy-soccer-client",
        "flappy-soccer-server"
      ],
      "depends_on": [
        {
          "package": "@openfederation/sdk",
          "source_repo": "OpenFederationPDS",
          "version": "IIFE v1 (pds-hosted)"
        },
        {
          "package": "@grvty/leaderboard-api",
          "source_repo": "grvty-leaderboards",
          "version": "v1 HTTP API"
        }
      ]
    }
  ]
}
