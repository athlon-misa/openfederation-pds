{
  "name": "@open-federation/sdk",
  "version": "0.1.1",
  "description": "Vanilla JS SDK for OpenFederation PDS — registration, login, and session management",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./global": {
      "types": "./dist/global.d.ts",
      "default": "./dist/index.global.js"
    }
  },
  "typesVersions": {
    "*": {
      ".": [
        "./dist/index.d.ts"
      ],
      "global": [
        "./dist/global.d.ts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsup && cp src/global.d.ts dist/global.d.ts",
    "dev": "tsup --watch",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "peerDependencies": {
    "ethers": ">=6.0.0"
  },
  "peerDependenciesMeta": {
    "ethers": {
      "optional": true
    }
  },
  "keywords": [
    "openfederation",
    "atproto",
    "sdk",
    "did",
    "decentralized"
  ],
  "license": "MIT OR Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/athlon-misa/openfederation-pds",
    "directory": "packages/openfederation-sdk"
  },
  "dependencies": {
    "@noble/curves": "^1.9.7",
    "@noble/hashes": "^1.8.0",
    "@scure/bip32": "^1.7.0",
    "@scure/bip39": "^1.6.0",
    "bs58": "^6.0.0",
    "ed25519-hd-key": "^1.3.0",
    "tweetnacl": "^1.0.3"
  }
}
