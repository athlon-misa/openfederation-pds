{
  "name": "@openfederation/sdk",
  "version": "0.1.0",
  "description": "Vanilla JS SDK for OpenFederation PDS — registration, login, and session management",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./global": {
      "types": "./dist/global.d.ts",
      "default": "./dist/index.global.js"
    }
  },
  "typesVersions": {
    "*": {
      ".": ["./dist/index.d.ts"],
      "global": ["./dist/global.d.ts"]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && cp src/global.d.ts dist/global.d.ts",
    "dev": "tsup --watch",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "keywords": [
    "openfederation",
    "atproto",
    "sdk",
    "did",
    "decentralized"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/OpenFederationPDS/OpenFederationPDS"
  }
}
