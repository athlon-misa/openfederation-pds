  },
  
  "security_baseline": {
    "password_requirements": {
      "min_length": 8,
      "require_uppercase": false,
      "require_lowercase": false,
      "require_numbers": false,
      "require_special_chars": false,
      "reasoning": "Minimum 8 characters required, additional complexity optional for better UX"
    },
    "password_hashing": {
      "algorithm": "bcrypt",
      "work_factor": 12,
      "library": "bcrypt npm package",
      "reasoning": "Industry standard, resistant to rainbow tables and brute force"
    },
    "session_tokens": {
      "access_token_ttl": "15 minutes",
      "refresh_token_ttl": "30 days",
      "algorithm": "JWT (HS256)",
      "storage": "Access token in memory, refresh token in httpOnly cookie or secure storage",
      "rotation": "Refresh token rotates on each use (optional)"
    },
    "rate_limiting": {
      "login_attempts": "5 per email per 15 minutes",
      "registration_attempts": "3 per IP per hour",
      "token_refresh": "10 per refresh token per hour"
    }
  },
  
  "user_registration": {
    "flows": [
      {
        "flow_name": "User Registration with Admin Approval",
        "description": "New users register with email/password and await admin approval before login",
        "steps": [
          {
            "step": 1,
            "action": "User submits registration form",
            "api_endpoint": "POST /xrpc/net.openfederation.account.register",
            "request_body": {
              "handle": "string (3-255 chars, lowercase, alphanumeric, hyphens)",
              "email": "string (valid email format)",
              "password": "string (min 8 characters)",
              "inviteCode": "string (optional, required if INVITE_REQUIRED=true)"
            },
            "validation": [
              "Email format validation (RFC 5322)",
              "Handle uniqueness check",
              "Email uniqueness check",
              "Password length >= 8 characters",
              "Invite code validation (if INVITE_REQUIRED=true)"
            ]
          },
          {
            "step": 2,
            "action": "System creates user with pending status",
            "side_effects": [
              "Hash password with bcrypt (work factor 12)",
              "Generate DID for user (did:plc)",
              "Create user record with status='pending'",
              "Increment invite code uses_count (if invite used)",
              "Send confirmation email to user",
              "Notify admins of pending approval (optional)"
            ],
            "database_changes": [
              "INSERT INTO users (id, did, handle, email, password_hash, status, role, created_at)",
              "UPDATE invite_codes SET uses_count = uses_count + 1 WHERE code = ? (if invite used)"
            ]
          },
          {
            "step": 3,
            "action": "User receives confirmation email",
            "email_template": "registration_pending",
            "email_content": {
              "subject": "Account Registration Pending",
              "body": "Your account has been created and is awaiting admin approval. You'll receive an email once approved."
            }
          },
          {
            "step": 4,
            "action": "Admin reviews and approves account",
            "api_endpoint": "POST /xrpc/net.openfederation.account.approve",
            "authorization": "Requires role='admin'",
            "request_body": {
              "userId": "UUID"
            },
            "side_effects": [
              "Update user status to 'approved'",
              "Set approved_at timestamp",
              "Set approved_by to admin user ID",
              "Send approval email to user"
            ]
          },
          {
            "step": 5,
            "action": "User receives approval email",
            "email_template": "account_approved",
            "email_content": {
              "subject": "Account Approved - Welcome to OpenFederation",
              "body": "Your account has been approved! You can now log in and create communities."
            }
          }
        ],
        "security_considerations": [
          "Admin approval prevents spam and abuse",
          "Invite codes provide controlled access",
          "Passwords never stored in plaintext",
          "DID generation follows AT Protocol standards",
          "Rate limiting prevents bulk registrations"
        ]
      },
      {
        "flow_name": "Admin Rejection Flow",
        "description": "Admin can reject pending accounts",
        "steps": [
          {
            "step": 1,
            "action": "Admin rejects account",
            "api_endpoint": "POST /xrpc/net.openfederation.account.reject",
            "authorization": "Requires role='admin'",
            "request_body": {
              "userId": "UUID"
            },
            "side_effects": [
              "Delete user record",
              "Decrement invite code uses_count (if invite was used)",
              "Send rejection email (optional)"
            ]
          }
        ]
      }
    ]
  },
  
  "login_flow": {
    "flows": [
      {
        "flow_name": "Email/Password Login with JWT Sessions",
        "description": "Standard login using AT Protocol session creation",
        "steps": [
          {
            "step": 1,
            "action": "User submits credentials",
            "api_endpoint": "POST /xrpc/com.atproto.server.createSession",
            "request_body": {
              "identifier": "string (email or handle)",
              "password": "string"
            },
            "validation": [
              "Check identifier format (email or handle)",
              "Rate limit: 5 attempts per identifier per 15 minutes"
            ]
          },
          {
            "step": 2,
            "action": "System validates credentials",
            "processing": [
              "Look up user by email or handle",
              "Verify user exists",
              "Check user status = 'approved'",
              "Compare password with bcrypt hash",
              "Check rate limit for failed attempts"
            ],
            "error_cases": [
              {
                "condition": "User not found",
                "response": "401 AuthenticationRequired - Invalid credentials"
              },
              {
                "condition": "Password incorrect",
                "response": "401 AuthenticationRequired - Invalid credentials"
              },
              {
                "condition": "Status = 'pending'",
                "response": "403 AccountNotApproved - Account pending approval"
              },
              {
                "condition": "Status = 'rejected'",
                "response": "403 Forbidden - Account rejected"
              },
              {
                "condition": "Rate limit exceeded",
                "response": "429 Too Many Requests - Try again later"
              }
            ]
          },
          {
            "step": 3,
            "action": "System creates session",
            "side_effects": [
              "Generate access JWT (15 min TTL)",
              "Generate refresh JWT (30 day TTL)",
              "Create session record in database",
              "Update last_login_at timestamp",
              "Clear failed login attempts counter"
            ],
            "jwt_access_token_payload": {
              "sub": "user.did",
              "type": "access",
              "iss": "pds.openfederation.net",
              "aud": "pds.openfederation.net",
              "iat": "timestamp",
              "exp": "timestamp + 15 minutes",
              "scope": "com.atproto.access"
            },
            "jwt_refresh_token_payload": {
              "sub": "user.did",
              "type": "refresh",
              "iss": "pds.openfederation.net",
              "aud": "pds.openfederation.net",
              "iat": "timestamp",
              "exp": "timestamp + 30 days",
              "scope": "com.atproto.refresh"
            }
          },
          {
            "step": 4,
            "action": "Return session to client",
            "response_body": {
              "did": "user.did",
              "handle": "user.handle",
              "email": "user.email",
              "accessJwt": "JWT access token",
              "refreshJwt": "JWT refresh token"
            },
            "status_code": 200
          }
        ],
        "security_considerations": [
          "Timing attack protection (constant-time password comparison)",
          "Failed login attempts are rate limited",
          "Generic error messages prevent user enumeration",
          "Sessions tracked in database for revocation",
          "JWT tokens signed with secret key",
          "Refresh tokens can be rotated for enhanced security"
        ]
      }
    ]
  },
  
  "session_management": {
    "get_current_session": {
      "api_endpoint": "GET /xrpc/com.atproto.server.getSession",
      "authorization": "Requires valid access JWT",
      "description": "Returns information about current authenticated session",
      "response": {
        "did": "user.did",
        "handle": "user.handle",
        "email": "user.email"
      }
    },
    "refresh_session": {
      "api_endpoint": "POST /xrpc/com.atproto.server.refreshSession",
      "authorization": "Requires valid refresh JWT",
      "description": "Uses refresh token to get new access token",
      "request": {
        "header": "Authorization: Bearer <refresh_jwt>"
      },
      "response": {
        "accessJwt": "new access token",
        "refreshJwt": "new refresh token (optional rotation)",
        "handle": "user.handle",
        "did": "user.did"
      },
      "token_rotation": {
        "enabled": false,
        "description": "If enabled, refresh token is rotated on each use (Phase 2)"
      }
    },
    "logout": {
      "description": "Client-side logout by clearing tokens",
      "implementation": "Web interface clears tokens from storage, no server call needed in Phase 1",
      "phase_2_enhancement": "Add server-side session invalidation endpoint"
    }
  },
  
