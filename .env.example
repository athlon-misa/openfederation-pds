# ============================================================
# OpenFederation PDS — Environment Configuration
# ============================================================
# Copy this file to .env and fill in the values.
# For Railway deployment, set these as service variables in the Dashboard.

# --- Server ---
PORT=3000
NODE_ENV=development

# --- Database ---
# Railway: auto-configured when you add a PostgreSQL service.
# Use the Railway reference variables: ${{Postgres.PGHOST}}, etc.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=openfederation_pds
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_SSL=false
# When DB_SSL=true, set to false only if using self-signed certificates (not recommended for production).
# DB_SSL_REJECT_UNAUTHORIZED=false
DB_MAX_POOL_SIZE=20
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=5000

# --- PDS Identity ---
PDS_HOSTNAME=pds.openfederation.net
PDS_SERVICE_URL=https://pds.openfederation.net

# --- PLC Directory ---
# For local development, run: npm run plc:dev (starts on port 2582)
# For Railway production: https://plc.openfederation.net (our own PLC service)
# For public PLC directory: https://plc.directory
PLC_DIRECTORY_URL=http://localhost:2582

# --- Handle Suffix ---
HANDLE_SUFFIX=.openfederation.net

# --- Auth ---
# REQUIRED: Random string, at least 32 characters. Server refuses to start in production without this.
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_JWT_SECRET=
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=30d
INVITE_REQUIRED=true

# --- Key Encryption ---
# REQUIRED for production: Encrypts recovery and signing keys at rest.
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
KEY_ENCRYPTION_SECRET=

# --- CORS ---
# Comma-separated origins allowed to call the PDS API.
# For Railway: set to your web UI service URL (e.g., https://your-web-ui.up.railway.app)
CORS_ORIGINS=http://localhost:3001

# --- Bootstrap Admin ---
# On first startup (with database connected), the PDS will create an admin user
# with these credentials if all three are set. The account is auto-approved and
# granted admin + moderator + user roles. You can then log in via the web UI.
#
# After initial setup you can remove these variables — the admin account persists
# in the database. If the account already exists, the PDS ensures it has admin role.
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_HANDLE=admin
BOOTSTRAP_ADMIN_PASSWORD=

# --- Partner API ---
# Allows trusted third-party apps to register users without invite codes.
# Keys are created via the admin API endpoint (net.openfederation.partner.createKey).
PARTNER_API_ENABLED=true
PARTNER_DEFAULT_RATE_LIMIT=100

# --- ATProto OAuth ---
# OAuth is enabled by default. Set to false to disable OAuth endpoints.
OAUTH_ENABLED=true
# DPoP nonce signing secret (hex). Must be same across all instances.
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
OAUTH_DPOP_SECRET=
# ES256 signing key for OAuth tokens (JWK JSON). Auto-generated in dev if empty.
OAUTH_SIGNING_KEY=
# Comma-separated list of trusted OAuth client_id URLs (optional).
OAUTH_TRUSTED_CLIENTS=
# Redis URL for OAuth replay protection. Falls back to in-memory for development.
# For Railway: add a Redis service and use ${{Redis.REDIS_URL}}
REDIS_URL=

# --- Email (SMTP) ---
# When SMTP_HOST is set, emails are sent via SMTP.
# When unset, emails are logged to console (development mode).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@openfederation.net

# --- Express Trust Proxy ---
# Number of proxy hops to trust for X-Forwarded-For (default: 1)
# Set to 2 for Cloudflare + Railway, or true to trust all proxies
EXPRESS_TRUST_PROXY=1

# --- ActivityPub ---
# ActivityPub identity layer is enabled by default.
# Set to false to disable AP actor endpoints and WebFinger AP links.
ACTIVITYPUB_ENABLED=true

# --- Federation ---
# Peer PDS discovery and cross-PDS federation.
# Comma-separated list of peer PDS base URLs (exclude this PDS's own URL).
FEDERATION_PEERS_ENABLED=true
PEER_PDS_URLS=
FEDERATION_CACHE_TTL_MS=300000
# Web UI URL used in federation metadata (optional).
WEB_UI_URL=

# --- Blob Storage ---
# Blob storage for avatars and banners.
# BLOB_STORAGE=local uses BLOB_STORAGE_PATH on disk; =s3 uses AWS S3 (or compatible).
BLOB_STORAGE=local
BLOB_STORAGE_PATH=./data/blobs
# Maximum blob size in bytes (default: 1048576 = 1MB).
BLOB_MAX_SIZE=1048576
# S3-compatible blob storage (only used when BLOB_STORAGE=s3).
BLOB_S3_BUCKET=
BLOB_S3_REGION=us-east-1
BLOB_S3_ENDPOINT=
BLOB_S3_ACCESS_KEY_ID=
BLOB_S3_SECRET_ACCESS_KEY=

# --- Chain Proof Verification ---
# Comma-separated chain adapters for on-chain governance proof verification.
# Format: chainId=rpcUrl (CAIP-2 chain IDs). RPC URLs may contain API keys — treat as secrets.
# Example: eip155:137=https://polygon-rpc.com/v2/YOUR_KEY,eip155:1=https://eth-mainnet.alchemyapi.io/v2/YOUR_KEY
CHAIN_ADAPTERS=

# --- Export Scheduler ---
# Background scheduler for community/user data exports.
# Disabled by default; enable to allow scheduled export jobs.
EXPORT_SCHEDULER_ENABLED=false
EXPORT_CHECK_INTERVAL_MS=300000
