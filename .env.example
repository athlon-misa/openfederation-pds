# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=openfederation_pds
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_SSL=false
DB_MAX_POOL_SIZE=20
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=5000

# PDS Configuration
PDS_HOSTNAME=pds.openfederation.net
PDS_SERVICE_URL=https://pds.openfederation.net

# PLC Directory
PLC_DIRECTORY_URL=https://plc.directory

# Handle Suffix
HANDLE_SUFFIX=.openfederation.net

# Auth Configuration
# IMPORTANT: Set to a random string of at least 32 characters. Server refuses to start in production without this.
AUTH_JWT_SECRET=
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=30d
INVITE_REQUIRED=true

# Key Encryption Secret
# IMPORTANT: Required for encrypting recovery and signing keys at rest. Must be set before creating communities.
KEY_ENCRYPTION_SECRET=

# CORS (comma-separated origins for web UI)
CORS_ORIGINS=http://localhost:3001

# Bootstrap Admin (optional - creates an admin user on startup)
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_HANDLE=
BOOTSTRAP_ADMIN_PASSWORD=
